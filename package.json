{
  "name": "tianyan-batch-ip-block-tool",
  "version": "0.1.4",
  "private": true,
  "description": "Local GUI tool for batch blocking IPs exported from Tianyan alerts.",
  "type": "module",
  "main": "src/electron-main.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win portable --publish never",
    "dist:mac": "electron-builder --mac zip --publish never",
    "dist:linux": "electron-builder --linux AppImage tar.gz --publish never"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.anjiajia.tianyanBatchIpBlockTool",
    "productName": "Tianyan Batch IP Block Tool",
    "asar": true,
    "files": [
      "src/**/*",
      "public/**/*",
      "config.example.json",
      "whitelist.txt",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "portable"
      ],
      "artifactName": "tianyan-batch-ip-block-tool-${version}-windows-${arch}-portable.${ext}",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "zip"
      ],
      "artifactName": "tianyan-batch-ip-block-tool-${version}-mac-${arch}.${ext}",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "artifactName": "tianyan-batch-ip-block-tool-${version}-linux-${arch}.${ext}"
    }
  },
  "author": "anjiajia <1334352581@qq.com>"
}
