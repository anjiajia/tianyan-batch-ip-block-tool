{
  "name": "tianyan-batch-ip-block-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Local GUI tool for batch blocking IPs exported from Tianyan alerts.",
  "type": "module",
  "main": "src/electron-main.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.anjiajia.tianyanBatchIpBlockTool",
    "productName": "天眼批量封禁工具",
    "asar": true,
    "files": [
      "src/**/*",
      "public/**/*",
      "config.example.json",
      "whitelist.txt",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": ["nsis", "portable"],
      "artifactName": "${productName}-${version}-windows-${arch}.${ext}"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "artifactName": "${productName}-${version}-mac-${arch}.${ext}"
    },
    "linux": {
      "target": ["AppImage", "deb", "tar.gz"],
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}"
    }
  }
}
