{
  "name": "tianyan-batch-ip-block-tool",
  "version": "0.1.10",
  "private": true,
  "description": "Local GUI tool for importing SOC alert exports, extracting IPs, filtering whitelist/duplicates, and batch blocking them on firewall devices.",
  "type": "module",
  "main": "src/electron-main.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/server.js",
    "electron": "electron .",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win nsis portable --publish never",
    "dist:mac": "electron-builder --mac zip --publish never",
    "dist:linux": "electron-builder --linux AppImage tar.gz --publish never",
    "dist:win:signed": "electron-builder --win nsis portable --publish never -c.win.signAndEditExecutable=true"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.anjiajia.tianyanBatchIpBlockTool",
    "productName": "SOC Batch IP Block Tool",
    "asar": true,
    "files": [
      "src/**/*",
      "public/**/*",
      "build/icons/**/*",
      "config.example.json",
      "whitelist.txt",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "zip"
      ],
      "icon": "build/icons/icon.icns",
      "hardenedRuntime": true,
      "artifactName": "tianyan-batch-ip-block-tool-${version}-mac-${arch}.${ext}",
      "identity": null
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "icon": "build/icons",
      "category": "Utility",
      "artifactName": "tianyan-batch-ip-block-tool-${version}-linux-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "anjiajia",
        "repo": "tianyan-batch-ip-block-tool",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SOC批量封禁工具",
      "artifactName": "tianyan-batch-ip-block-tool-${version}-windows-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "tianyan-batch-ip-block-tool-${version}-windows-${arch}-portable.${ext}"
    }
  },
  "author": "anjiajia <1334352581@qq.com>",
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/anjiajia/tianyan-batch-ip-block-tool.git"
  }
}
